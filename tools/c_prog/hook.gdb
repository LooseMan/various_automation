# ============================================================
# GDB one-shot hook script
#
# 用途:
#   特定関数が呼ばれたタイミングで処理をフックし、
#   任意の値をreturnしてGDBを終了する。
#
# 実行例:
#   gdb -batch -q -p <PID> -x hook.gdb &
#
# 動作:
#   1. 対象プロセスへattach
#   2. 指定関数の呼び出しを待機
#   3. 関数本体を実行せず return
#   4. detach
#   5. GDB終了
#
# 注意:
#   - 関数名は環境に応じて変更すること
#   - return値は必要に応じて変更すること
#   - C++関数は demangle名 を指定する
#   - attach時に対象プロセスは一時停止する
# ============================================================

# ページ送り無効
set pagination off

# quit時の確認無効
set confirm off

# ------------------------------------------------------------
# 一回だけ有効なbreakpoint
#
# 関数名は環境に応じて変更すること
# 例:
#   tbreak Class::Func(int)
#   tbreak Namespace::Class::Request(std::string const&)
# ------------------------------------------------------------
tbreak sim::Client::Request(int)

# ------------------------------------------------------------
# breakpointヒット時の自動実行処理
# ------------------------------------------------------------
commands

    # breakpoint停止メッセージ抑制
    silent

    # ログ出力（必要なら変更）
    printf "hooked!\n"

    # --------------------------------------------------------
    # 関数本体を実行せず即return
    #
    # return値は必要に応じて変更すること
    # --------------------------------------------------------
    return 0

    # --------------------------------------------------------
    # 対象プロセスからdetach
    #
    # detach後も対象アプリは継続動作する
    # --------------------------------------------------------
    detach

    # GDB終了
    quit

end

# ------------------------------------------------------------
# attach後に停止している対象プロセスを再開
#
# このcontinueが無いとbreak待機に入らない
# ------------------------------------------------------------
continue
